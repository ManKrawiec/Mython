{
  "name": "Mython",
  "scopeName": "source.mython",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mython",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mython",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mython",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.mython",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mython",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mython",
          "match": "\\b(jeżeli|inaczej|dopóki|dla|w|funkcja|zwróć|to|oraz|lub)\\b"
        },
        {
          "name": "constant.language.boolean.mython",
          "match": "\\b(prawda|fałsz)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.mython",
          "match": "\\b(wypisz|czytaj|zakres|zakresie)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mython",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    }
  }
}
